# Copy this file to .env and fill in your values
# Get your token from: https://discord.com/developers/applications -> Bot -> Reset Token
DISCORD_TOKEN=your_bot_token_here

# ── Optional: YouTube anti-bot bypass ────────────────────────────────────────
# Set YTDL_COOKIES_FILE to a Netscape-format cookies.txt exported from your browser
# (use the "Export Cookies" extension). This greatly improves reliability on server IPs.
# YTDL_COOKIES_FILE=/app/cookies.txt

# Set YTDL_PO_TOKEN to a YouTube Proof-of-Origin token if you have one.
# See: https://github.com/yt-dlp/yt-dlp/wiki/Extractors#po-token-guide
# YTDL_PO_TOKEN=your_po_token_here
